# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/trustcomply

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES=7d

# PACE (trust-people) payroll integration
PACE_API_URL=https://pace.mytrustlab.co.in/api/v1
PACE_API_KEY=your_pace_api_key

# TAMS (medical licence) integration
TAMS_API_URL=https://tams.example.co.in/api
TAMS_API_KEY=your_tams_api_key
